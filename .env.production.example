# Copy to .env.production and fill values
FLASK_ENV=production
FLASK_APP=run.py
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DB=bikehub_prod
MYSQL_USER=bikehub
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root
FLASK_SECRET_KEY=replace_with_secure_value
JWT_SECRET_KEY=replace_with_secure_value
CORS_ORIGINS=*
LOG_FILE=/var/log/bikehub/app.log
